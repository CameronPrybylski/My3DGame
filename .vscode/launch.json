{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "LLDB Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/game/My3DGame",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "My3DGame_ROOT",
          "value": "/Users/cameronprzybylski/Documents/C++/C++ Projects/My3DGame"
        }
      ],
      "externalConsole": false,
      "MIMode": "lldb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb/lldb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
